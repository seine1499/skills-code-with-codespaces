{
  // この開発環境の名前
  "name": "Codespace for Skills!",
  
  // 使用するベースイメージ（VS Codeの公式イメージ）
  "image": "mcr.microsoft.com/vscode/devcontainers/universal:latest",

  // コンテナ内で使用するユーザー
  "remoteUser": "codespace",

  // デフォルトコマンドの上書きを無効化
  "overrideCommand": false

  ,
 // コンテナ作成時にインストールする拡張機能と開くファイルの設定
 "customizations": {
     "vscode": {
         "extensions": [
             "GitHub.copilot"
         ]
     },
     "codespaces": {
         "openFiles": [
             "codespace.md"
         ]
     }
 }

}
